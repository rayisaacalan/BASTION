set.seed(128000822)
source('util_graph.R')
ns=100; ## the number of locations
coords=data.frame(lon=runif(ns),lat=runif(ns))
graph0=ConstructSpatGraph(coords) ## by default, generate a 4NN graph
graph0=ConstructSpatGraph(coords,method.g='CDT',0.5); ## generate a CDT graph
## Create edge id and vertex id attributes for easier tracking in subsequent analysis
E(graph0)$eid = c(1:ecount(graph0))  # edge id
V(graph0)$vid = c(1:vcount(graph0))  # vertex id
plotSpatGraph(graph0,coords)
nc=4; # number of clusters
membership=GenerateClust(graph0,nc=nc,eps.nc=10) ## the smallest cluster size is 10
plotSpatGraphClust(graph0,coords,membership)
truebeta=c(-1,-0.5,0.5,1);sigma=0.1;
Y=truebeta[membership]+rnorm(ns,0,sd=sigma) ## noisy piecewise constant
plotSpatGraphData(graph0,coords,Y)
## determine whether an edge is 'b' (between cluster) or 'w' (within cluster)
edge_status_G=getEdgeStatus(membership, graph0)
##
mstgraph=proposeMST(graph0,edge_status_G) ## check the function in util.graph for details
plotSpatGraphClust(mstgraph,coords,membership)
## determine whether an edge is 'b' (between cluster) or 'w' (within cluster)
edge_status_G=getEdgeStatus(membership, graph0)
##
mstgraph=proposeMST(graph0,edge_status_G) ## check the function in util.graph for details
plotSpatGraphClust(mstgraph,coords,membership)
## determine whether an edge is 'b' (between cluster) or 'w' (within cluster)
edge_status_G=getEdgeStatus(membership, graph0)
##
mstgraph=proposeMST(graph0,edge_status_G) ## check the function in util.graph for details
plotSpatGraphClust(mstgraph,coords,membership)
## determine whether an edge is 'b' (between cluster) or 'w' (within cluster)
edge_status_G=getEdgeStatus(membership, graph0)
##
mstgraph=proposeMST(graph0,edge_status_G) ## check the function in util.graph for details
plotSpatGraphClust(mstgraph,coords,membership)
